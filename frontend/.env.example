# Golden Oak AR — Frontend Environment Variables

# Backend API base URL (must end in /api)
# For local development this is handled by the Vite proxy,
# so you can leave it unset or set to '/api'.
# For production, point this at your deployed backend, e.g.:
# VITE_API_URL=https://my-backend.up.railway.app/api
VITE_API_URL=

# ─── Optional integrations ───────────────────────────────────
# The app works without any of these — it gracefully falls back to
# mock data / placeholder text when keys are missing.

# Firebase (for Firestore sync + Auth)
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=

# Gemini API key (for AI-generated tasting notes)
# SECURITY NOTE: In production this should be proxied through a
# Cloud Function so the key never ships to the client bundle.
VITE_GEMINI_API_KEY=
